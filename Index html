<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Batman Watch Order</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:black;
  color:white;
}

/* HERO */
.hero{
  padding:20px;
  text-align:center;
}
.hero h1{font-size:28px}

.full-video iframe{
  width:100%;
  height:220px;
  border:none;
}

.btn{
  background:red;
  color:white;
  padding:10px 20px;
  border:none;
  margin-top:10px;
}

/* SEARCH */
.search-box{
  display:none;
  text-align:center;
  margin:20px;
}
.search-box input{
  width:70%;
  padding:10px;
}

/* TIMELINES */
.timelines{
  display:none;
  text-align:center;
}
.timelines button{
  margin:5px;
  padding:8px;
  border:1px solid red;
  background:#111;
  color:white;
}

/* GRID */
.section{
  display:none;
  padding:15px;
}
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(120px,1fr));
  gap:12px;
}

.card{
  background:#111;
  border-radius:8px;
  overflow:hidden;
  transition:0.3s;
}
.card:hover{
  transform:scale(1.05);
}

.card img{
  width:100%;
  height:160px;
  object-fit:cover;
}

.card .info{
  padding:8px;
}

.card h3{
  font-size:12px;
  color:red;
}

.watch{
  background:red;
  border:none;
  color:white;
  padding:5px;
  width:100%;
}

/* MODAL */
.modal{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:black;
  display:none;
}
.modal iframe{
  width:100%;
  height:250px;
}
.close{
  background:red;
  border:none;
  color:white;
  padding:10px;
}
</style>
</head>

<body>

<!-- HERO -->
<div class="hero">

<h1>WATCH ORDER</h1>

<p contenteditable="true">
Most people watch Batman animated movies completely wrong. They jump between timelines, universes, and versions without understanding the continuity — turning a powerful story into confusion.
</p>

<div class="full-video">
<iframe id="mainVideo" src=""></iframe>
</div>

<p contenteditable="true">
When you follow the correct order, Batman’s journey becomes deeper, more emotional, and more connected. You understand his evolution and Gotham’s true impact.
</p>

<button class="btn" onclick="openSearch()">WATCH ORDER</button>

<br><br>

<a href="https://youtube.com/" target="_blank">
<button class="btn">YouTube</button>
</a>

</div>

<!-- SEARCH -->
<div class="search-box" id="searchBox">
<input id="searchInput" placeholder="Search movie..." onkeyup="searchMovie()">
</div>

<!-- TIMELINES -->
<div class="timelines" id="timelines">
<button onclick="showSection('dcau')">DCAU</button>
<button onclick="showSection('dcamu')">DCAMU</button>
<button onclick="showSection('tomorrow')">TOMORROWVERSE</button>
<button onclick="showSection('standalone')">STANDALONE</button>
<button onclick="showSection('uaom')">DCUAOM</button>
</div>

<!-- SECTIONS -->
<div id="dcau" class="section"><div class="grid" id="dcauGrid"></div></div>
<div id="dcamu" class="section"><div class="grid" id="dcamuGrid"></div></div>
<div id="tomorrow" class="section"><div class="grid" id="tomorrowGrid"></div></div>
<div id="standalone" class="section"><div class="grid" id="standaloneGrid"></div></div>
<div id="uaom" class="section"><div class="grid" id="uaomGrid"></div></div>

<!-- MODAL -->
<div class="modal" id="modal">
<button class="close" onclick="closeVideo()">Close</button>
<h2>Summary</h2>
<iframe id="videoFrame"></iframe>
</div>

<script>

/* OPEN SEARCH */
function openSearch(){
  document.getElementById("searchBox").style.display="block";
  document.getElementById("timelines").style.display="block";
}

/* SHOW SECTION */
function showSection(id){
  document.querySelectorAll(".section").forEach(s=>s.style.display="none");
  document.getElementById(id).style.display="block";
}

/* SEARCH */
function searchMovie(){
  let val=document.getElementById("searchInput").value.toLowerCase();
  document.querySelectorAll(".card").forEach(c=>{
    c.style.display=c.innerText.toLowerCase().includes(val)?"block":"none";
  });
}

/* VIDEO */
function playVideo(link){
  document.getElementById("modal").style.display="block";
  document.getElementById("videoFrame").src=link;
}
function closeVideo(){
  document.getElementById("modal").style.display="none";
  document.getElementById("videoFrame").src="";
}

/* CARD */
function createCard(name){
return `
<div class="card">
<img src="https://via.placeholder.com/150x200">
<div class="info">
<h3>${name}</h3>
<p style="font-size:10px">Release: (Add)</p>
<p style="font-size:10px">Director: (Add)</p>
<p style="font-size:10px">Cast: (Add)</p>
<button class="watch" onclick="playVideo('https://www.youtube.com/embed/dQw4w9WgXcQ')">WATCH</button>
</div>
</div>`;
}

/* DATA */
const dcau=["Batman Mask of the Phantasm","Batman Mr Freeze Subzero","Batman Beyond Return of the Joker","Batman Mystery of the Batwoman","Batman and Harley Quinn"];

const dcamu=["Justice League Flashpoint Paradox","Justice League War","Son of Batman","Justice League Throne of Atlantis","Batman vs Robin","Batman Bad Blood","Justice League Teen Titans","Justice League Dark","The Death of Superman","Reign of the Superman","Batman Hush","Justice League Dark Apokolips War"];

const tomorrow=["Batman Long Halloween Part 1","Batman Long Halloween Part 2","Legion of Superheroes","Justice League Warworld","Crisis on Infinite Earths Part 1","Part 2","Part 3"];

const standalone=["Batman vs Dracula","Batman Gotham Knight","Justice League Crisis on Two Earths","Batman Under the Red Hood","Batman Year One","Dark Knight Returns Part 1","Part 2","Superman Unbound","Batman Assault on Arkham","Batman Killing Joke","Return of Caped Crusader","Lego Batman","Batman vs Two Face","Gotham by Gaslight","Batman Ninja","Batman vs TMNT","Death in the Family","Soul of the Dragon","Injustice","Battle of the Super Sons","Doom that came to Gotham","Merry Little Batman","Aztec Batman","Batman Ninja vs Yakuza League"];

const uaom=["Superman Batman Public Enemies","Superman Batman Apocalypse","Batman Unlimited Animal Instincts","Monster Mayhem","Mech vs Mutants"];

/* RENDER */
function render(id,data){
document.getElementById(id).innerHTML=data.map(createCard).join("");
}

render("dcauGrid",dcau);
render("dcamuGrid",dcamu);
render("tomorrowGrid",tomorrow);
render("standaloneGrid",standalone);
render("uaomGrid",uaom);

</script>

</body>
</html>
